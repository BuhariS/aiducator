DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=0

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Keep 1 for local development without Redis; set 0 when running a Celery worker.
CELERY_TASK_ALWAYS_EAGER=1

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Aiducator <no-reply@aiducator.local>
PASSWORD_RESET_TIMEOUT=3600

SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_SSL_REDIRECT=0

STORAGE_BACKEND=filesystem
AWS_STORAGE_BUCKET_NAME=
AWS_STATIC_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=0

AI_LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=
AI_PROMPT_VERSION=grading-v1
AI_COURSE_PROMPT_VERSION=course-generation-v1
AI_FIELD_ENCRYPTION_KEY=
AI_ALLOWED_EMBED_HOSTS=youtube.com,youtube-nocookie.com,youtu.be,vimeo.com,phet.colorado.edu
AI_RATE_LIMIT_COURSE_GENERATION=5
AI_RATE_LIMIT_ATTEMPT=20
SANDBOX_IMAGE=python:3.12-alpine
SANDBOX_MAX_SOURCE_LENGTH=12000
SANDBOX_MAX_PROCESSES=32
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_CPU_SECONDS=2
SANDBOX_WALL_TIME_SECONDS=5
AI_INPUT_COST_PER_1K=0
AI_OUTPUT_COST_PER_1K=0
